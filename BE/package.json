{
	"name": "shop-cart-backend-project",
	"version": "1.0.0",
	"description": "Take home evaluation project for backend engineering candidates",
	"author": "SAM",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate",
		"prisma:migrate:dev": "prisma migrate dev",
		"prisma:migrate:deploy": "prisma migrate deploy",
		"tsc:build": "tsc --project tsconfig.json --noEmit",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage"
	},
	"prisma": {
		"schema": "src/modules/prisma/schema.prisma"
	},
	"dependencies": {
		"@fastify/static": "^8.1.1",
		"@nestjs/axios": "^4.0.0",
		"@nestjs/common": "^11.0.20",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.0.20",
		"@nestjs/jwt": "^11.0.0",
		"@nestjs/mapped-types": "*",
		"@nestjs/passport": "^11.0.0",
		"@nestjs/platform-fastify": "^11.0.20",
		"@nestjs/swagger": "^11.1.5",
		"@prisma/client": "^6.6.0",
		"axios": "^1.8.4",
		"bcrypt": "^5.1.1",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"nestjs-zod": "^4.3.1",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"project-shared": "file:../shared",
		"reflect-metadata": "^0.2.2",
		"uuid": "^11.1.0",
		"zod": "^3.24.3",
		"zod-validation-error": "^3.4.0"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.6",
		"@nestjs/schematics": "^11.0.5",
		"@nestjs/testing": "^11.0.20",
		"@suites/di.nestjs": "^3.0.1",
		"@suites/doubles.jest": "^3.0.1",
		"@suites/unit": "^3.0.1",
		"@types/bcrypt": "^5.0.2",
		"@types/jest": "^29.5.14",
		"@types/passport-jwt": "^4.0.1",
		"@types/node": "^22.14.1",
		"jest": "^29.7.0",
		"prisma": "^6.6.0",
		"ts-jest": "^29.4.5",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.3"
	},
	"jest": {
		"moduleFileExtensions": ["js", "json", "ts"],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": ["**/*.(t|j)s"],
		"coverageDirectory": "../coverage",
		"coveragePathIgnorePatterns": [
			"src/modules/module-bis/generated/*",
			"src/modules/module-healthcheck/*",
			"src/modules/module-otel/*",
			"src/modules/module-config/*",
			"env.schema.ts",
			"logger.config.ts",
			".module.ts",
			".exception.ts",
			".schema.ts",
			"main.ts",
			"index.ts"
		],
		"testEnvironment": "node",
		"moduleNameMapper": {
			"^src/(.*)$": "<rootDir>/$1"
		},
		"modulePaths": ["."]
	}
}
